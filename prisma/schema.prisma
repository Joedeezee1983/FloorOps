generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TECH
  SUPERVISOR
  ADMIN
}

enum MachineStatus {
  ONLINE
  OFFLINE
  WARNING
  MAINTENANCE
}

enum ProgressiveType {
  NONE
  STANDALONE
  LINKED
  WIDE_AREA
}

enum ShiftType {
  DAY
  SWING
  NIGHT
}

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
}

enum TaskType {
  DOWN_MACHINE
  GENERAL
  MAINTENANCE_REQUEST
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum TaskSection {
  PRE_EXISTING_DOWN
  FLOOR_GAMES
  KIOSKS
  BENCH_OFFICE
  MISCELLANEOUS
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(true)
  image         String?
  password      String?
  role            UserRole  @default(TECH)
  isActive        Boolean   @default(true)
  locationId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  location     Location?    @relation(fields: [locationId], references: [id])
  sessions     Session[]
  accounts     Account[]
  shifts       Shift[]      @relation("ShiftSupervisor")
  shiftStaff   ShiftStaff[]
  tokens       UserToken[]
  partRequests PartRequest[]

  @@index([email])
  @@index([locationId])
  @@index([isActive])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum TokenType {
  INVITE
  PASSWORD_RESET
  EMAIL_CONFIRM
}

enum PartUrgency {
  NORMAL
  URGENT
}

enum PartStatus {
  PENDING
  ORDERED
  RECEIVED
}

model UserToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique @default(cuid())
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  payload   String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Location {
  id          String   @id @default(cuid())
  name        String
  description String?
  floorNumber Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users     User[]
  machines  Machine[]
  shifts    Shift[]
  blueprint FloorBlueprint?
  settings  SystemSettings?

  @@index([name])
}

model Machine {
  id              String          @id @default(cuid())
  assetNumber     String          @unique
  bankNumber      String
  gameName        String
  gameBrand       String
  gameType        String
  progressiveType ProgressiveType @default(NONE)
  denomination    Float
  softwareVersion String?
  status          MachineStatus   @default(ONLINE)
  gridX           Int?
  gridY           Int?
  locationId      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  location     Location?          @relation(fields: [locationId], references: [id])
  statusLogs   MachineStatusLog[]
  shiftTasks   ShiftTask[]
  partRequests PartRequest[]

  @@index([locationId])
  @@index([status])
  @@index([assetNumber])
  @@index([gameBrand])
  @@index([gameType])
}

model MachineStatusLog {
  id        String        @id @default(cuid())
  machineId String
  status    MachineStatus
  note      String?
  changedAt DateTime      @default(now())

  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId])
  @@index([changedAt])
}

model FloorBlueprint {
  id         String   @id @default(cuid())
  locationId String   @unique
  imageUrl   String
  opacity    Float    @default(0.3)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId])
}

model Shift {
  id           String      @id @default(cuid())
  type         ShiftType
  status       ShiftStatus @default(SCHEDULED)
  locationId   String
  supervisorId String?
  startTime    DateTime
  endTime      DateTime
  headcount    Int         @default(0)
  briefing     String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  location     Location       @relation(fields: [locationId], references: [id])
  supervisor   User?          @relation("ShiftSupervisor", fields: [supervisorId], references: [id])
  tasks        ShiftTask[]
  staff        ShiftStaff[]
  aiBriefing   ShiftBriefing?
  partRequests PartRequest[]

  @@index([locationId])
  @@index([supervisorId])
  @@index([startTime])
  @@index([status])
}

model ShiftTask {
  id           String      @id @default(cuid())
  shiftId      String
  type         TaskType
  section      TaskSection @default(MISCELLANEOUS)
  description  String
  status       TaskStatus  @default(PENDING)
  machineId    String?
  loggedByName String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  shift   Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  machine Machine? @relation(fields: [machineId], references: [id])

  @@index([shiftId])
  @@index([machineId])
  @@index([status])
}

model ShiftStaff {
  id      String @id @default(cuid())
  shiftId String
  userId  String

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([shiftId, userId])
  @@index([shiftId])
  @@index([userId])
}

model ShiftBriefing {
  id        String   @id @default(cuid())
  shiftId   String   @unique
  content   String
  createdAt DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id                String   @id @default(cuid())
  locationId        String   @unique
  dayShiftStart     String   @default("06:00")
  dayShiftEnd       String   @default("14:00")
  swingShiftStart   String   @default("14:00")
  swingShiftEnd     String   @default("22:00")
  nightShiftStart   String   @default("22:00")
  nightShiftEnd     String   @default("06:00")
  shiftTimeoutHours Int      @default(10)
  inventoryEmail    String?

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId])
}

model PartRequest {
  id            String      @id @default(cuid())
  machineId     String?
  shiftId       String?
  requestedById String
  name          String
  description   String?
  quantity      Int         @default(1)
  urgency       PartUrgency @default(NORMAL)
  status        PartStatus  @default(PENDING)
  orderedAt     DateTime?
  receivedAt    DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  machine     Machine? @relation(fields: [machineId], references: [id])
  shift       Shift?   @relation(fields: [shiftId], references: [id])
  requestedBy User     @relation(fields: [requestedById], references: [id])

  @@index([machineId])
  @@index([shiftId])
  @@index([requestedById])
  @@index([status])
  @@index([createdAt])
}
