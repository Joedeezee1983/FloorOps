generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TECH
  SUPERVISOR
  ADMIN
}

enum MachineStatus {
  ONLINE
  OFFLINE
  WARNING
  MAINTENANCE
}

enum ProgressiveType {
  NONE
  STANDALONE
  LINKED
  WIDE_AREA
}

enum ShiftType {
  DAY
  SWING
  NIGHT
}

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(TECH)
  locationId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  location Location? @relation(fields: [locationId], references: [id])
  sessions Session[]
  accounts Account[]
  shifts   Shift[]   @relation("ShiftSupervisor")

  @@index([email])
  @@index([locationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Location {
  id          String   @id @default(cuid())
  name        String
  description String?
  floorNumber Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users    User[]
  machines Machine[]
  shifts   Shift[]

  @@index([name])
}

model Machine {
  id              String          @id @default(cuid())
  assetNumber     String          @unique
  bankNumber      String
  gameName        String
  gameBrand       String
  gameType        String
  progressiveType ProgressiveType @default(NONE)
  denomination    Float
  softwareVersion String?
  status          MachineStatus   @default(ONLINE)
  gridX           Int?
  gridY           Int?
  locationId      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  location   Location?          @relation(fields: [locationId], references: [id])
  statusLogs MachineStatusLog[]

  @@index([locationId])
  @@index([status])
  @@index([assetNumber])
  @@index([gameBrand])
  @@index([gameType])
}

model MachineStatusLog {
  id        String        @id @default(cuid())
  machineId String
  status    MachineStatus
  note      String?
  changedAt DateTime      @default(now())

  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId])
  @@index([changedAt])
}

model Shift {
  id           String      @id @default(cuid())
  type         ShiftType
  status       ShiftStatus @default(SCHEDULED)
  locationId   String
  supervisorId String?
  startTime    DateTime
  endTime      DateTime
  headcount    Int         @default(0)
  briefing     String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  location   Location @relation(fields: [locationId], references: [id])
  supervisor User?    @relation("ShiftSupervisor", fields: [supervisorId], references: [id])

  @@index([locationId])
  @@index([supervisorId])
  @@index([startTime])
  @@index([status])
}
